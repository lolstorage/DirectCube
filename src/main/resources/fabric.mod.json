{
	"schemaVersion": 1,
	"id": "directcube",
	"version": "${version}",
	"name": "DirectCube",
	"description": "DirectCube is a optimization mod for minecraft that lets you use D3D9 as the renderer instead of OpenGL",
	"authors": [
		"LolStorage"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/directcube/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"direct.cube.DirectCube"
		]
	},
	"mixins": [
		"directcube.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}
